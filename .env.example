# PathwAI runs fully offline by default. Everything below is OPTIONAL and only
# needed if you want a real LLM proposer. Copy to `.env` to use.

# --- Proposer backend ---
# stub (default, offline noisy heuristic) | random (ablation) |
# ollama (needs: pip install "pathwai[ollama]" + a running ollama server) |
# openai (needs: pip install "pathwai[openai]" + OPENAI_API_KEY)
PATHWAI_PROPOSER_BACKEND=stub

# --- What to run by default ---
# Domain : gridworld | blocksworld | delivery
# Planner: optimal | uniform | greedy | llm | llm_search
PATHWAI_DOMAIN=gridworld
PATHWAI_PLANNER=llm_search

# --- Tunables (deterministic; tweak for experiments) ---
# PATHWAI_SEED=7
# PATHWAI_MAX_EXPANSIONS=5000
# PATHWAI_STUB_NOISE=0.55          # 0 = perfect heuristic; higher = worse guide

# --- Optional real-LLM backends ---
# PATHWAI_OLLAMA_MODEL=llama3.1:8b
# PATHWAI_OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
